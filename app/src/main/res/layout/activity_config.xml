<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/config_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── Sticky Preview (widget_clock.xml inflated here at runtime) ── -->
    <FrameLayout
        android:id="@+id/preview_container"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_gravity="center_horizontal"
        android:layout_margin="16dp"/>

    <ScrollView
        android:id="@+id/config_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- ── Locale ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/config_locale_label"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/edit_locale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:importantForAutofill="no"
                android:hint="@string/config_locale_hint"
                android:layout_marginBottom="16dp"/>

            <!-- ── Skeleton ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/config_skeleton_label"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/edit_skeleton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="textNoSuggestions"
                    android:importantForAutofill="no"
                    android:hint="@string/config_skeleton_hint"/>
                <Button
                    android:id="@+id/btn_set_skeleton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/set"
                    style="?attr/borderlessButtonStyle"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- ── Pattern ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/config_pattern_label"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/edit_pattern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:importantForAutofill="no"
                android:hint="@string/config_pattern_hint"
                android:layout_marginBottom="16dp"/>

            <!-- ── Style Toolbar ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bold"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    app:icon="@drawable/ic_format_bold"
                    android:contentDescription="Bold"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_italic"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    app:icon="@drawable/ic_format_italic"
                    android:contentDescription="Italic"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_text_size"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_format_size"
                    android:contentDescription="Text size"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_text_color"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_format_color_text"
                    android:contentDescription="Text color"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bg_color"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_palette"
                    android:contentDescription="Background color"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_font_family"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_font_family"
                    android:contentDescription="Font family"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_shadow"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_shadow"
                    android:contentDescription="Text shadow"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_stroke"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_stroke"
                    android:contentDescription="Text outline"/>

            </LinearLayout>

            <CheckBox
                android:id="@+id/checkbox_bitmap_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="High-quality rendering (shadow &amp; stroke)"
                android:layout_marginTop="8dp"/>

            <CheckBox
                android:id="@+id/checkbox_compose_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Compose rendering (Google Fonts)"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
